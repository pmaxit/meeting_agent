# ── Required ──────────────────────────────────────────────────────────────────
# Port map: see features/agentic-runtime/README.md. These values are
# deployment parameters; keep them aligned with the deploy env you are running.

# API Gateway — main entry point for meeting/transcript/bot operations
VEXA_API_URL=http://localhost:8056

# Public API URL — browser-facing URL for the API gateway
# (compose injects this as http://localhost:${API_GATEWAY_HOST_PORT})
VEXA_PUBLIC_API_URL=http://localhost:8056

# Admin API — user/token management (direct, bypasses api-gateway auth)
VEXA_ADMIN_API_URL=http://localhost:8056
# Must match ADMIN_API_TOKEN in deploy/.env (compose passes it as VEXA_ADMIN_API_KEY)
VEXA_ADMIN_API_KEY=changeme

# ── Auth ──────────────────────────────────────────────────────────────────────
# Auth mode is auto-detected: if no OAuth is configured, uses "direct" mode
# (email → instant login, no email verification needed)
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=vexa-dev-secret
JWT_SECRET=vexa-dev-jwt-secret

# App URL (browser-facing)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Required for local dev when SMTP is not configured (email sign-in without magic link)
VEXA_ALLOW_DIRECT_LOGIN=true

# ── Optional: Agent API ───────────────────────────────────────────────────────
# AGENT_API_URL=http://localhost:8100
# AGENT_API_TOKEN=

# ── Optional: AI assistant + Jira intent detection ───────────────────────────
# Used by the AI chat panel and /agent Jira intent extraction (LLM path).
# Pattern-based detection works without these; set them for richer extraction.
# AI_MODEL=openai/gpt-4o
# AI_API_KEY=
# AI_BASE_URL=
# OpenRouter example:
# AI_MODEL=openrouter/openai/gpt-4o-mini
# AI_API_KEY=your-openrouter-key
# AI_BASE_URL=https://openrouter.ai/api/v1

# ── Optional: default bot config ──────────────────────────────────────────────
# DEFAULT_BOT_NAME=Nova

# ── Optional: Google OAuth ────────────────────────────────────────────────────
# ENABLE_GOOGLE_AUTH=true
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Optional: Microsoft / Azure AD OAuth ──────────────────────────────────────
# ENABLE_MICROSOFT_AUTH=true
# ENABLE_AZURE_AD_AUTH=true
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=

# ── Optional: email authentication (magic link via SMTP) ─────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# ── Optional: Zoom OAuth ─────────────────────────────────────────────────────
# ZOOM_OAUTH_CLIENT_ID=
# ZOOM_OAUTH_CLIENT_SECRET=
# ZOOM_OAUTH_REDIRECT_URI=
# ZOOM_OAUTH_STATE_SECRET=

# ── Optional: Google Calendar integration ─────────────────────────────────────
# GOOGLE_CALENDAR_REDIRECT_URI=

# ── Optional: transcript sharing and docs URLs ────────────────────────────────
# NEXT_PUBLIC_TRANSCRIPT_SHARE_BASE_URL=https://share.example.com
# NEXT_PUBLIC_BASE_URL=https://dashboard.example.com
# NEXT_PUBLIC_WEBAPP_URL=https://webapp.vexa.ai

# ── Optional: registration policy ────────────────────────────────────────────
# ALLOW_REGISTRATIONS=true
# ALLOWED_EMAIL_DOMAINS=
